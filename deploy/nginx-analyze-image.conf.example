# Snippet for nginx in front of ai-services (port 3000).
# Without this, nginx returns 413 before Node sees the request (empty pm2 logs).

location /ai/ {
    client_max_body_size 180m;
    proxy_pass http://127.0.0.1:3000/ai/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# If you strip /ai and forward to Node as /analyze-image instead:
# location /ai/ {
#     client_max_body_size 180m;
#     proxy_pass http://127.0.0.1:3000/;
# }
